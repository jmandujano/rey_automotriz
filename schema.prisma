model MovimientoFinanciero {
  id_movimiento              Int                     @id @default(autoincrement()) @map("id_movimiento")
  tipo_movimiento            String                  @map("tipo_movimiento") @db.VarChar(20)
  id_categoria_financiera    Int?                    @map("id_categoria_financiera")
  razon                      String?                 @map("razon") @db.VarChar(100)
  monto                      Decimal                 @map("monto") @db.Decimal(12, 2)
  fecha_movimiento           DateTime                @map("fecha_movimiento") @db.Date
  numero_comprobante         String?                 @map("numero_comprobante") @db.VarChar(50)
  numero_operacion_bancaria  String?                 @map("numero_operacion_bancaria") @db.VarChar(50)
  descripcion                String?                 @map("descripcion")
  id_usuario_registro        Int                     @map("id_usuario_registro")
  estado_computo             String?                 @default("computado") @map("estado_computo") @db.VarChar(20)
  fecha_registro             DateTime?               @default(now()) @map("fecha_registro") @db.Timestamp(6)
  fecha_ultima_actualizacion DateTime?               @default(now()) @map("fecha_ultima_actualizacion") @db.Timestamp(6)
  id_cuota                   Int?
  comisiones                 ComisionVendedor[]      @relation("ComisionMovimiento")
  comprobantes               MovimientoComprobante[]
  movimientoPedidos          MovimientoPedido[]
  categoria                  CategoriaFinanciera?    @relation(fields: [id_categoria_financiera], references: [id_categoria_financiera], onDelete: NoAction, onUpdate: NoAction)
  pedido_cuotas              pedido_cuotas?          @relation(fields: [id_cuota], references: [id_cuota], onDelete: NoAction, onUpdate: NoAction)
  usuario                    Usuario                 @relation("MovimientoRegistrador", fields: [id_usuario_registro], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_categoria_financiera], map: "idx_movimientos_categoria")
  @@index([estado_computo], map: "idx_movimientos_estado")
  @@index([fecha_movimiento], map: "idx_movimientos_fecha")
  @@index([tipo_movimiento], map: "idx_movimientos_tipo")
  @@index([id_usuario_registro], map: "idx_movimientos_usuario")
  @@map("movimientos_financieros")
}

