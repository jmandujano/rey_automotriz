generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Role {
  id_rol         Int       @id @default(autoincrement()) @map("id_rol")
  nombre_rol     String    @unique @map("nombre_rol") @db.VarChar(50)
  descripcion    String?   @map("descripcion")
  fecha_creacion DateTime? @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  usuarios       Usuario[]

  @@map("roles")
}

model Usuario {
  id_usuario                 Int                         @id @default(autoincrement()) @map("id_usuario")
  id_rol                     Int                         @map("id_rol")
  correo_electronico         String                      @unique @map("correo_electronico") @db.VarChar(100)
  contrasena_hash            String                      @map("contrasena_hash") @db.VarChar(255)
  nombre_completo            String                      @map("nombre_completo") @db.VarChar(150)
  dni                        String?                     @map("dni") @db.VarChar(8)
  fecha_nacimiento           DateTime?                   @map("fecha_nacimiento") @db.Date
  telefono_principal         String?                     @map("telefono_principal") @db.VarChar(20)
  telefono_secundario        String?                     @map("telefono_secundario") @db.VarChar(20)
  estado                     String?                     @default("activo") @map("estado") @db.VarChar(20)
  requiere_cambio_contrasena Boolean?                    @default(false) @map("requiere_cambio_contrasena")
  fecha_creacion             DateTime?                   @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  fecha_ultima_actualizacion DateTime?                   @default(now()) @map("fecha_ultima_actualizacion") @db.Timestamp(6)
  fecha_ultimo_acceso        DateTime?                   @map("fecha_ultimo_acceso") @db.Timestamp(6)
  ajustes_inventario         ajustes_inventario[]
  clientesAsignados          Cliente[]                   @relation("VendedorClientes")
  comisiones                 ComisionVendedor[]
  devolucionHistorial        DevolucionHistorialEstado[]
  devoluciones_creacion      Devolucion[]                @relation("DevolucionCreador")
  devoluciones_actualizacion Devolucion[]                @relation("DevolucionActualizador")
  devoluciones_vendedor      Devolucion[]                @relation("DevolucionVendedor")
  movimientosFinancieros     MovimientoFinanciero[]      @relation("MovimientoRegistrador")
  pedidoComentarios          PedidoComentario[]
  pedidoHistorial            PedidoHistorialEstado[]
  pedidos_creacion           Pedido[]                    @relation("PedidoCreador")
  pedidos_actualizacion      Pedido[]                    @relation("PedidoActualizador")
  pedidos_vendedor           Pedido[]                    @relation("PedidoVendedor")
  proformas                  Proforma[]                  @relation("ProformaCreador")
  proformasVendedor          Proforma[]                  @relation("ProformaVendedor")
  rol                        Role                        @relation(fields: [id_rol], references: [id_rol], onDelete: NoAction, onUpdate: NoAction)
  clienteVisitas             VisitaCliente[]

  @@index([correo_electronico], map: "idx_usuarios_correo")
  @@index([estado], map: "idx_usuarios_estado")
  @@index([id_rol], map: "idx_usuarios_rol")
  @@map("usuarios")
}

model Cliente {
  id_cliente                 Int              @id @default(autoincrement()) @map("id_cliente")
  id_vendedor_asignado       Int              @map("id_vendedor_asignado")
  ruc                        String?          @unique @map("ruc") @db.VarChar(11)
  razon_social               String           @map("razon_social") @db.VarChar(200)
  nombre_representante       String?          @map("nombre_representante") @db.VarChar(150)
  cumpleanos_representante   DateTime?        @map("cumpleanos_representante") @db.Date
  correo_electronico         String           @unique @map("correo_electronico") @db.VarChar(100)
  telefono_principal         String?          @map("telefono_principal") @db.VarChar(20)
  telefono_secundario        String?          @map("telefono_secundario") @db.VarChar(20)
  dni_representante          String?          @map("dni_representante") @db.VarChar(8)
  tipo_cliente               String?          @map("tipo_cliente") @db.VarChar(20)
  departamento               String?          @map("departamento") @db.VarChar(50)
  provincia                  String?          @map("provincia") @db.VarChar(50)
  distrito                   String?          @map("distrito") @db.VarChar(50)
  direccion                  String?          @map("direccion")
  estado                     String?          @default("activo") @map("estado") @db.VarChar(20)
  fecha_creacion             DateTime?        @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  fecha_ultima_actualizacion DateTime?        @default(now()) @map("fecha_ultima_actualizacion") @db.Timestamp(6)
  adjuntos                   ClienteAdjunto[]
  vendedor                   Usuario          @relation("VendedorClientes", fields: [id_vendedor_asignado], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  devoluciones               Devolucion[]
  pedidos                    Pedido[]
  proformas                  Proforma[]
  visitas                    VisitaCliente[]

  @@index([estado], map: "idx_clientes_estado")
  @@index([ruc], map: "idx_clientes_ruc")
  @@index([id_vendedor_asignado], map: "idx_clientes_vendedor")
  @@map("clientes")
}

model ClienteAdjunto {
  id_adjunto     Int       @id @default(autoincrement()) @map("id_adjunto")
  id_cliente     Int       @map("id_cliente")
  tipo_adjunto   String    @map("tipo_adjunto") @db.VarChar(50)
  nombre_archivo String    @map("nombre_archivo") @db.VarChar(255)
  ruta_archivo   String    @map("ruta_archivo")
  fecha_subida   DateTime? @default(now()) @map("fecha_subida") @db.Timestamp(6)
  cliente        Cliente   @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction)

  @@map("cliente_adjuntos")
}

model VisitaCliente {
  id_visita        Int       @id @default(autoincrement()) @map("id_visita")
  id_vendedor      Int       @map("id_vendedor")
  id_cliente       Int       @map("id_cliente")
  fecha_visita     DateTime  @map("fecha_visita") @db.Date
  hora_visita      DateTime  @map("hora_visita") @db.Time(6)
  contador_visitas Int?      @default(1) @map("contador_visitas")
  fecha_registro   DateTime? @default(now()) @map("fecha_registro") @db.Timestamp(6)
  cliente          Cliente   @relation(fields: [id_cliente], references: [id_cliente], onDelete: Cascade, onUpdate: NoAction)
  vendedor         Usuario   @relation(fields: [id_vendedor], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@unique([id_vendedor, id_cliente, fecha_visita])
  @@index([fecha_visita], map: "idx_visitas_fecha")
  @@index([id_vendedor, id_cliente], map: "idx_visitas_vendedor_cliente")
  @@map("visitas_clientes")
}

model CategoriaProducto {
  id_categoria            Int                 @id @default(autoincrement()) @map("id_categoria")
  nombre_categoria        String              @unique @map("nombre_categoria") @db.VarChar(100)
  id_categoria_padre      Int?                @map("id_categoria_padre")
  porcentaje_alerta_stock Decimal?            @default(10.00) @map("porcentaje_alerta_stock") @db.Decimal(5, 2)
  descripcion             String?             @map("descripcion")
  fecha_creacion          DateTime?           @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  categoriaPadre          CategoriaProducto?  @relation("CategoriaPadre", fields: [id_categoria_padre], references: [id_categoria], onDelete: NoAction, onUpdate: NoAction)
  subcategorias           CategoriaProducto[] @relation("CategoriaPadre")
  productos               Producto[]

  @@map("categorias_producto")
}

model Proveedor {
  id_proveedor     Int                   @id @default(autoincrement()) @map("id_proveedor")
  nombre_proveedor String                @map("nombre_proveedor") @db.VarChar(200)
  tipo_origen      String?               @map("tipo_origen") @db.VarChar(20)
  ruc              String?               @map("ruc") @db.VarChar(11)
  contacto         String?               @map("contacto") @db.VarChar(100)
  telefono         String?               @map("telefono") @db.VarChar(20)
  email            String?               @map("email") @db.VarChar(100)
  direccion        String?               @map("direccion")
  estado           String?               @default("activo") @map("estado") @db.VarChar(20)
  fecha_creacion   DateTime?             @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  importaciones    ProductoImportacion[]

  @@map("proveedores")
}

model Almacen {
  id_almacen     Int       @id @default(autoincrement()) @map("id_almacen")
  nombre_almacen String    @unique @map("nombre_almacen") @db.VarChar(100)
  ubicacion      String?   @map("ubicacion")
  estado         String?   @default("activo") @map("estado") @db.VarChar(20)
  fecha_creacion DateTime? @default(now()) @map("fecha_creacion") @db.Timestamp(6)

  @@map("almacenes")
}

model Producto {
  id_producto                Int                       @id @default(autoincrement()) @map("id_producto")
  codigo_producto            String                    @unique @map("codigo_producto") @db.VarChar(255)
  descripcion                String                    @map("descripcion")
  id_categoria               Int                       @map("id_categoria")
  stock                      Int
  advertencia_stock          Int
  alerta_stock               Int
  estado                     String?                   @default("activo") @map("estado") @db.VarChar(20)
  fecha_creacion             DateTime?                 @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  fecha_ultima_actualizacion DateTime?                 @default(now()) @map("fecha_ultima_actualizacion") @db.Timestamp(6)
  ajustes_inventario         ajustes_inventario[]
  devolucionDetalles         DevolucionDetalle[]
  pedidoDetalles             PedidoDetalle[]
  imagenes                   ProductoImagen[]
  importaciones              ProductoImportacion[]
  porcentajesVenta           ProductoPorcentajeVenta[]
  categoria                  CategoriaProducto         @relation(fields: [id_categoria], references: [id_categoria], onDelete: NoAction, onUpdate: NoAction)
  proformaDetalles           ProformaDetalle[]

  @@index([id_categoria], map: "idx_productos_categoria")
  @@index([codigo_producto], map: "idx_productos_codigo")
  @@index([estado], map: "idx_productos_estado")
  @@map("productos")
}

model ProductoImportacion {
  id_importacion          Int                  @id @default(autoincrement()) @map("id_importacion")
  id_producto             Int                  @map("id_producto")
  id_proveedor            Int                  @map("id_proveedor")
  fecha_importacion       DateTime             @map("fecha_importacion") @db.Date
  precio_compra           Decimal              @map("precio_compra") @db.Decimal(12, 2)
  precio_venta_a          Decimal              @db.Decimal(12, 2)
  precio_venta_b          Decimal?             @db.Decimal(12, 2)
  precio_venta_c          Decimal?             @db.Decimal(12, 2)
  precio_venta_d          Decimal?             @db.Decimal(12, 2)
  precio_venta_e          Decimal?             @db.Decimal(12, 2)
  precio_venta_f          Decimal?             @db.Decimal(12, 2)
  precio_venta_comision_a Decimal              @db.Decimal(12, 2)
  precio_venta_comision_b Decimal?             @db.Decimal(12, 2)
  precio_venta_comision_c Decimal?             @db.Decimal(12, 2)
  precio_venta_comision_d Decimal?             @db.Decimal(12, 2)
  precio_venta_comision_e Decimal?             @db.Decimal(12, 2)
  precio_venta_comision_f Decimal?             @db.Decimal(12, 2)
  margen_a                Decimal              @db.Decimal(5, 2)
  margen_b                Decimal?             @db.Decimal(5, 2)
  margen_c                Decimal?             @db.Decimal(5, 2)
  margen_d                Decimal?             @db.Decimal(5, 2)
  margen_e                Decimal?             @db.Decimal(5, 2)
  margen_f                Decimal?             @db.Decimal(5, 2)
  comision_a              Decimal              @db.Decimal(5, 2)
  comision_b              Decimal?             @db.Decimal(5, 2)
  comision_c              Decimal?             @db.Decimal(5, 2)
  comision_d              Decimal?             @db.Decimal(5, 2)
  comision_e              Decimal?             @db.Decimal(5, 2)
  comision_f              Decimal?             @db.Decimal(5, 2)
  cantidad                Int?                 @default(0)
  estado_importacion      String?              @map("estado_importacion") @db.VarChar(20)
  observaciones           String?
  fecha_creacion          DateTime?            @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  ajustes_inventario      ajustes_inventario[]
  producto                Producto             @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade, onUpdate: NoAction)
  proveedor               Proveedor            @relation(fields: [id_proveedor], references: [id_proveedor], onDelete: NoAction, onUpdate: NoAction)

  @@index([estado_importacion], map: "idx_importaciones_estado")
  @@index([id_producto], map: "idx_importaciones_producto")
  @@map("producto_importaciones")
}

model ProductoPorcentajeVenta {
  id_porcentaje_venta   Int       @id @default(autoincrement()) @map("id_porcentaje_venta")
  id_producto           Int       @map("id_producto")
  porcentaje_margen     Decimal   @map("porcentaje_margen") @db.Decimal(5, 2)
  precio_venta          Decimal   @map("precio_venta") @db.Decimal(12, 2)
  porcentaje_comision   Decimal   @map("porcentaje_comision") @db.Decimal(5, 2)
  precio_venta_comision Decimal   @db.Decimal(12, 2)
  fecha_vigencia_inicio DateTime? @default(dbgenerated("CURRENT_DATE")) @map("fecha_vigencia_inicio") @db.Date
  fecha_vigencia_fin    DateTime? @map("fecha_vigencia_fin") @db.Date
  estado                String?   @default("activo") @map("estado") @db.VarChar(20)
  fecha_creacion        DateTime? @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  producto              Producto  @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade, onUpdate: NoAction)

  @@map("producto_porcentajes_venta")
}

model ProductoImagen {
  id_imagen           Int       @id @default(autoincrement()) @map("id_imagen")
  id_producto         Int       @map("id_producto")
  nombre_archivo      String    @map("nombre_archivo") @db.VarChar(255)
  ruta_archivo        String    @map("ruta_archivo")
  orden_visualizacion Int?      @default(1) @map("orden_visualizacion")
  fecha_subida        DateTime? @default(now()) @map("fecha_subida") @db.Timestamp(6)
  producto            Producto  @relation(fields: [id_producto], references: [id_producto], onDelete: Cascade, onUpdate: NoAction)

  @@map("producto_imagenes")
}

model Pedido {
  id_pedido                       Int                     @id @default(autoincrement()) @map("id_pedido")
  id_cliente                      Int                     @map("id_cliente")
  id_vendedor                     Int                     @map("id_vendedor")
  tipo_pago                       String                  @map("tipo_pago") @db.VarChar(20)
  tipo_comprobante                String                  @map("tipo_comprobante") @db.VarChar(20)
  numero_comprobante              String?                 @map("numero_comprobante") @db.VarChar(50)
  subtotal                        Decimal?                @map("subtotal") @db.Decimal(12, 2)
  igv                             Decimal?                @map("igv") @db.Decimal(12, 2)
  total                           Decimal                 @map("total") @db.Decimal(12, 2)
  observaciones                   String?                 @map("observaciones")
  estado_actual                   String?                 @default("registrado") @map("estado_actual") @db.VarChar(20)
  fecha_creacion                  DateTime?               @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  fecha_ultima_actualizacion      DateTime?               @default(now()) @map("fecha_ultima_actualizacion") @db.Timestamp(6)
  id_usuario_creacion             Int                     @map("id_usuario_creacion")
  id_usuario_ultima_actualizacion Int?                    @map("id_usuario_ultima_actualizacion")
  fecha_entrega                   DateTime?               @db.Timestamp(6)
  pago_inicial                    Decimal?                @db.Decimal(12, 2)
  estado_pago                     String?                 @db.VarChar(20)
  devoluciones                    Devolucion[]
  facturacion                     ElectronicaFactura[]
  movimientoPedidos               MovimientoPedido[]
  comentarios                     PedidoComentario[]
  cuotas                          pedido_cuotas[]
  detalles                        PedidoDetalle[]
  historial                       PedidoHistorialEstado[]
  cliente                         Cliente                 @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction)
  creador                         Usuario                 @relation("PedidoCreador", fields: [id_usuario_creacion], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  actualizador                    Usuario?                @relation("PedidoActualizador", fields: [id_usuario_ultima_actualizacion], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  vendedor                        Usuario                 @relation("PedidoVendedor", fields: [id_vendedor], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  proformasConvertidas            Proforma[]              @relation("ProformaConvertido")

  @@index([id_cliente], map: "idx_pedidos_cliente")
  @@index([estado_actual], map: "idx_pedidos_estado")
  @@index([fecha_creacion], map: "idx_pedidos_fecha")
  @@index([id_vendedor], map: "idx_pedidos_vendedor")
  @@map("pedidos")
}

model PedidoDetalle {
  id_detalle              Int      @id @default(autoincrement()) @map("id_detalle")
  id_pedido               Int      @map("id_pedido")
  id_producto             Int      @map("id_producto")
  cantidad                Int      @map("cantidad")
  comision                Decimal  @db.Decimal(5, 2)
  precio_compra           Decimal? @db.Decimal(12, 2)
  precio_venta            Decimal? @db.Decimal(12, 2)
  precio_venta_comision   Decimal? @db.Decimal(12, 2)
  subtotal_compra         Decimal? @db.Decimal(12, 2)
  subtotal_venta          Decimal? @db.Decimal(12, 2)
  subtotal_venta_comision Decimal? @db.Decimal(12, 2)
  subtotal_monto_comision Decimal? @db.Decimal(12, 2)
  pedido                  Pedido   @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade, onUpdate: NoAction)
  producto                Producto @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_pedido], map: "idx_pedido_detalle_pedido")
  @@index([id_producto], map: "idx_pedido_detalle_producto")
  @@map("pedido_detalle")
}

model PedidoHistorialEstado {
  id_historial    Int       @id @default(autoincrement()) @map("id_historial")
  id_pedido       Int       @map("id_pedido")
  estado_anterior String?   @map("estado_anterior") @db.VarChar(20)
  estado_nuevo    String    @map("estado_nuevo") @db.VarChar(20)
  id_usuario      Int       @map("id_usuario")
  fecha_cambio    DateTime? @default(now()) @map("fecha_cambio") @db.Timestamp(6)
  comentario      String?   @map("comentario")
  pedido          Pedido    @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade, onUpdate: NoAction)
  usuario         Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@map("pedido_historial_estados")
}

model PedidoComentario {
  id_comentario    Int       @id @default(autoincrement()) @map("id_comentario")
  id_pedido        Int       @map("id_pedido")
  id_usuario       Int       @map("id_usuario")
  comentario       String    @map("comentario")
  fecha_comentario DateTime? @default(now()) @map("fecha_comentario") @db.Timestamp(6)
  pedido           Pedido    @relation(fields: [id_pedido], references: [id_pedido], onDelete: Cascade, onUpdate: NoAction)
  usuario          Usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@map("pedido_comentarios")
}

model Proforma {
  id_proforma          Int               @id @default(autoincrement()) @map("id_proforma")
  id_cliente           Int               @map("id_cliente")
  id_vendedor          Int               @map("id_vendedor")
  numero_proforma      String?           @unique @map("numero_proforma") @db.VarChar(50)
  subtotal             Decimal           @map("subtotal") @db.Decimal(12, 2)
  igv                  Decimal           @map("igv") @db.Decimal(12, 2)
  total                Decimal           @map("total") @db.Decimal(12, 2)
  observaciones        String?           @map("observaciones")
  ruta_pdf             String?           @map("ruta_pdf")
  convertida_pedido    Boolean?          @default(false) @map("convertida_pedido")
  id_pedido_convertido Int?              @map("id_pedido_convertido")
  fecha_creacion       DateTime?         @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  id_usuario_creacion  Int               @map("id_usuario_creacion")
  detalles             ProformaDetalle[]
  cliente              Cliente           @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction)
  pedidoConvertido     Pedido?           @relation("ProformaConvertido", fields: [id_pedido_convertido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)
  creador              Usuario           @relation("ProformaCreador", fields: [id_usuario_creacion], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  vendedor             Usuario           @relation("ProformaVendedor", fields: [id_vendedor], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@map("proformas")
}

model ProformaDetalle {
  id_detalle      Int      @id @default(autoincrement()) @map("id_detalle")
  id_proforma     Int      @map("id_proforma")
  id_producto     Int      @map("id_producto")
  cantidad        Int      @map("cantidad")
  precio_unitario Decimal  @map("precio_unitario") @db.Decimal(12, 2)
  subtotal        Decimal  @map("subtotal") @db.Decimal(12, 2)
  producto        Producto @relation(fields: [id_producto], references: [id_producto], onDelete: NoAction, onUpdate: NoAction)
  proforma        Proforma @relation(fields: [id_proforma], references: [id_proforma], onDelete: Cascade, onUpdate: NoAction)

  @@map("proforma_detalle")
}

model ElectronicaFactura {
  id_facturacion        Int       @id @default(autoincrement()) @map("id_facturacion")
  id_pedido             Int       @map("id_pedido")
  tipo_documento        String?   @map("tipo_documento") @db.VarChar(20)
  numero_documento      String    @unique @map("numero_documento") @db.VarChar(50)
  xml_ubl               String    @map("xml_ubl")
  cdr_sunat             String?   @map("cdr_sunat")
  estado_sunat          String?   @map("estado_sunat") @db.VarChar(50)
  fecha_emision         DateTime? @default(now()) @map("fecha_emision") @db.Timestamp(6)
  fecha_respuesta_sunat DateTime? @map("fecha_respuesta_sunat") @db.Timestamp(6)
  pedido                Pedido    @relation(fields: [id_pedido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)

  @@map("facturacion_electronica")
}

model Devolucion {
  id_devolucion                   Int                         @id @default(autoincrement()) @map("id_devolucion")
  id_pedido                       Int                         @map("id_pedido")
  id_cliente                      Int                         @map("id_cliente")
  id_vendedor                     Int                         @map("id_vendedor")
  motivo                          String                      @map("motivo")
  estado_actual                   String?                     @default("registrada") @map("estado_actual") @db.VarChar(20)
  motivo_rechazo                  String?                     @map("motivo_rechazo")
  reembolsada                     Boolean?                    @default(false) @map("reembolsada")
  fecha_creacion                  DateTime?                   @default(now()) @map("fecha_creacion") @db.Timestamp(6)
  fecha_ultima_actualizacion      DateTime?                   @default(now()) @map("fecha_ultima_actualizacion") @db.Timestamp(6)
  id_usuario_creacion             Int                         @map("id_usuario_creacion")
  id_usuario_ultima_actualizacion Int?                        @map("id_usuario_ultima_actualizacion")
  detalles                        DevolucionDetalle[]
  evidencias                      DevolucionEvidencia[]
  historial                       DevolucionHistorialEstado[]
  cliente                         Cliente                     @relation(fields: [id_cliente], references: [id_cliente], onDelete: NoAction, onUpdate: NoAction)
  pedido                          Pedido                      @relation(fields: [id_pedido], references: [id_pedido], onDelete: NoAction, onUpdate: NoAction)
  creador                         Usuario                     @relation("DevolucionCreador", fields: [id_usuario_creacion], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  actualizador                    Usuario?                    @relation("DevolucionActualizador", fields: [id_usuario_ultima_actualizacion], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)
  vendedor                        Usuario                     @relation("DevolucionVendedor", fields: [id_vendedor], references: [id_usuario], onDelete: NoAction, onUpdate: NoAction)

  @@index([id_cliente], map: "idx_devoluciones_cliente")
  @@index([estado_actual], map: "idx_devoluciones_estado")
  @@index([fecha_creacion], map: "idx_devoluciones_fecha")
  @@index([id_pedido], map: "idx_devoluciones_pedido")
  @@index([id_vendedor], map: "idx_devoluciones_vendedor")
  @@map("devoluciones")
}

